{
    "compilerOptions": {
        "target": "ES2020",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "lib": ["ES2020", "DOM", "DOM.Iterable"],
        "strict": true,
        "exactOptionalPropertyTypes": false,
        "noUncheckedIndexedAccess": false,
        "declaration": true,
        "declarationDir": "dist",
        "declarationMap": true,
        "sourceMap": true,
        "outDir": "dist",
        "rootDir": ".",
        "skipLibCheck": true,
        "types": ["chrome", "node"],
        "paths": {
            "virtual:civil-ext-shim-source": ["./src/virtual-shim-source.d.ts"]
        }
    },
    "include": ["src/**/*"],
    "exclude": ["node_modules", "dist", "rollup.config.ts"]
}
